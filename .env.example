# ─────────────────────────────────────────────────────────────
# Premier Commerce Platform — environment
# Copy to apps/web/.env.local and fill in.
# ─────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Platform routing
# Root domain used to derive a tenant slug from the host header, e.g. a root of
# "premier.app" makes "bizrah.premier.app" resolve to slug "bizrah".
PLATFORM_ROOT_DOMAIN=premier.app
# Fallback tenant for local dev, where the host carries no tenant subdomain.
DEFAULT_TENANT_SLUG=bizrah

# M-Pesa Daraja (sandbox defaults; per-tenant credentials live in the database,
# in business_payment_configs, encrypted — these are process-level defaults only)
MPESA_ENV=sandbox
MPESA_API_BASE=https://sandbox.safaricom.co.ke
# Public HTTPS URL Daraja will POST the STK callback to:
MPESA_CALLBACK_BASE_URL=
