{
  "name": "premier-commerce",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant commerce platform. Bizrah Electronics is tenant #1.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev --workspace=@premier/web",
    "build": "npm run build --workspace=@premier/web",
    "start": "npm run start --workspace=@premier/web",
    "lint": "npm run lint --workspace=@premier/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff"
  }
}
